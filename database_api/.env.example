APP_ENV=local

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=biostec_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

API_KEY=change_this_to_a_long_random_secret
API_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
API_ALLOWED_TABLES=products,categories,users,orders,order_items,repair_tickets,user_addresses,inventory_logs
API_DEFAULT_LIMIT=50
API_MAX_LIMIT=200
API_READ_ONLY=1
