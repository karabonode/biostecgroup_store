# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=biostec_db
DB_CHARSET=utf8mb4
DB_PERSISTENT=1
DB_AUTO_CREATE=1
DB_CONNECT_RETRIES=3
DB_CONNECT_RETRY_DELAY_MS=400

# ── Frontend API ───────────────────────────────────────────────────────────────
# Vite app -> PHP API base URL
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# ── Local API Runtime (Node dev server) ───────────────────────────────────────
AUTO_START_PHP_API=1
PHP_API_ORIGIN=http://127.0.0.1:8000

# ── Yoco Payment ──────────────────────────────────────────────────────────────
# Get keys from https://dashboard.yoco.com/developers/api-keys
YOCO_PUBLIC_KEY=pk_test_...
YOCO_SECRET_KEY=sk_test_...
YOCO_WEBHOOK_SECRET=whsec_...
YOCO_WEBHOOK_ID=sub_...

# Exposed to Vite/React frontend (public key only — safe to commit)
VITE_YOCO_PUBLIC_KEY=pk_test_...

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=mail.yourdomain.co.za
SMTP_PORT=465
SMTP_USER=info@yourdomain.co.za
SMTP_PASS=your-email-password
ADMIN_EMAIL=admin@yourdomain.co.za
